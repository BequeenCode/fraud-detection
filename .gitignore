# Data (do not commit raw or processed datasets, but keep the folder structure)
data/*
!data/raw/
!data/processed/
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Models artifacts (large binaries)
models/*.pkl
models/*.joblib
models/*.json
models/*.txt

# Reports figures can be large; keep the markdown, ignore generated images optionally
# (figures are committed by default so the report renders on GitHub)

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# IDE / OS
.idea/
*.swp
.DS_Store
Thumbs.db

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
